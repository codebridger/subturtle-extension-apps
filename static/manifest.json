{
	"name": "Subturtle: Learn English with Subtitles, Videos & AI Coach",
	"description": "Learn English from any video or web page: tap a subtitle word for its meaning, save and review words, and speak with an AI coach.",
	"version": "1.15.1.1",
	"manifest_version": 3,
	"icons": {
		"128": "/assets/logo-128.png",
		"256": "/assets/logo-240.png"
	},
	"permissions": [
		"activeTab",
		"tabs",
		"storage",
		"identity"
	],
	"host_permissions": [
		"<all_urls>",
		"https://www.subturtle.app/",
		"https://www.dashboard.subturtle.app/",
		"https://translation.googleapis.com/",
		"https://api-js.mixpanel.com/",
		"https://ipapi.co/json/"
	],
	"oauth2": {
		"client_id": "344321252651-5db3ijl3vuqds5u1acbrkv0vhnsamqk1.apps.googleusercontent.com",
		"scopes": [
			"https://www.googleapis.com/auth/userinfo.email"
		]
	},
	"action": {
		"default_popup": "popup.html"
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": [
				"https://www.netflix.com/*"
			],
			"js": [
				"main.js"
			]
		},
		{
			"matches": [
				"https://www.youtube.com/*"
			],
			"css": [
				"/assets/style/youtube.css"
			],
			"js": [
				"main.js"
			]
		},
		{
			"matches": [
				"<all_urls>"
			],
			"js": [
				"nibble.js"
			]
		},
		{
			"matches": [
				"<all_urls>"
			],
			"js": [
				"console-crane.js"
			]
		}
	],
	"web_accessible_resources": [
		{
			"resources": [
				"assets/*"
			],
			"matches": [
				"<all_urls>"
			]
		}
	],
	"version_name": "1.15.1-dev.1"
}
